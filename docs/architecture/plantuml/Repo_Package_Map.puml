@startuml
skinparam packageStyle rectangle

title SageStore Repository Package Map (Current ERP MVP)

package "_client/" {
    [Dialogs] as Dialogs
    [MainWindow] as MainWindow
    [Users MVVM] as UsersMVVM
    [Inventory MVVM] as InventoryMVVM
    [Management MVVM] as ManagementMVVM
    [Purchase MVVM] as PurchaseMVVM
    [Sales MVVM] as SalesMVVM
    [Logs + Analytics MVVM] as ObservabilityMVVM
    [Settings + I18n] as SettingsI18n
    [ApiManager] as ApiManager
    [NetworkService] as NetworkService
}

package "_common/" {
    [Entities] as Entities
    [Dataset / Keys] as DatasetKeys
    [Endpoints] as Endpoints
    [JsonSerializer] as JsonSerializer
}

package "_server/" {
    [HttpServer / HttpTransaction] as HttpLayer
    [BusinessLogic] as BusinessLogic
    [UsersModule] as UsersModule
    [InventoryModule] as InventoryModule
    [ManagementModule] as ManagementModule
    [PurchaseModule] as PurchaseModule
    [SalesModule] as SalesModule
    [LogsModule] as LogsModule
    [AnalyticsModule] as AnalyticsModule
    [Repositories] as Repositories
    [SQLite manager] as SqliteManager
}

package "docs/" {
    [Implementation Status] as ImplStatus
    [Requirements Baseline] as ReqBaseline
    [PlantUML assets] as PlantUML
    [Release readiness docs] as ReleaseDocs
}

package "scripts + CI" {
    [build.py] as BuildScript
    [docs task] as DocsTask
    [markdown link check] as LinkCheck
    [Jenkinsfile] as Jenkins
}

Dialogs --> ApiManager
MainWindow --> UsersMVVM
MainWindow --> InventoryMVVM
MainWindow --> ManagementMVVM
MainWindow --> PurchaseMVVM
MainWindow --> SalesMVVM
MainWindow --> ObservabilityMVVM
MainWindow --> SettingsI18n
UsersMVVM --> ApiManager
InventoryMVVM --> ApiManager
ManagementMVVM --> ApiManager
PurchaseMVVM --> ApiManager
SalesMVVM --> ApiManager
ObservabilityMVVM --> ApiManager
SettingsI18n --> ApiManager
ApiManager --> NetworkService
NetworkService --> Endpoints
NetworkService --> JsonSerializer

HttpLayer --> BusinessLogic
BusinessLogic --> UsersModule
BusinessLogic --> InventoryModule
BusinessLogic --> ManagementModule
BusinessLogic --> PurchaseModule
BusinessLogic --> SalesModule
BusinessLogic --> LogsModule
BusinessLogic --> AnalyticsModule
UsersModule --> Repositories
InventoryModule --> Repositories
ManagementModule --> Repositories
PurchaseModule --> Repositories
SalesModule --> Repositories
LogsModule --> Repositories
AnalyticsModule --> Repositories
Repositories --> SqliteManager
Repositories --> Entities
ApiManager --> Entities

DocsTask --> PlantUML
BuildScript --> LinkCheck
Jenkins --> BuildScript
Jenkins --> ImplStatus
ReqBaseline --> PlantUML
ReleaseDocs --> PlantUML

@enduml
